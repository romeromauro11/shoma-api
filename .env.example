# =============================================
# SHOMA API - Variables de entorno
# =============================================
# Copiá este archivo como .env y completá los valores
# NUNCA subas el .env real a GitHub

# --- Base de datos (Railway te da estos datos) ---
DATABASE_URL=postgresql://usuario:contraseña@host:puerto/nombre_db

# --- Seguridad ---
# Generá una clave larga y aleatoria (mínimo 32 caracteres)
# Podés usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_secreta_32chars

# --- Admin de la tienda ---
ADMIN_EMAIL=tu@email.com
ADMIN_PASSWORD=tu_contraseña_segura

# --- Configuración ---
PORT=3001
NODE_ENV=development

# --- CORS: URL de tu tienda en Netlify ---
FRONTEND_URL=https://shoma-tienda.netlify.app
